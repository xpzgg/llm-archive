        <mxCell id="re8" value="virq" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r_core6" target="r_drv3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="640" y="1085"/><mxPoint x="640" y="1230"/></Array></mxGeometry></mxCell>
