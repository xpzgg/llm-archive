  <diagram id="trigger_model" name="中断触发心智模型">
    <mxGraphModel dx="1280" dy="1900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t_title" value="Linux arm64 中断触发：硬件事件如何找到注册时挂上的 handler" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="90" y="30" width="920" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t_lane_hw" value="外设 / GIC" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="230" height="1650" as="geometry"/>
        </mxCell>
        <mxCell id="t_lane_entry" value="arm64 exception entry" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="110" width="230" height="1650" as="geometry"/>
        </mxCell>
        <mxCell id="t_lane_core" value="irq core" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#e1f5e1;strokeColor=#82b366;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="110" width="230" height="1650" as="geometry"/>
        </mxCell>
        <mxCell id="t_lane_drv" value="驱动 handler" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="110" width="230" height="1650" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="外设拉起 IRQ&#xa;GIC 看到某个 INTID pending" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="75" y="170" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="GIC 选择目标 CPU&#xa;优先级、mask、affinity 共同决定是否送达" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="75" y="310" width="160" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="CPU 进入 IRQ exception&#xa;保存现场，切到 vector" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="335" y="310" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="el1h_64_irq_handler()&#xa;内核态常见入口；用户态会走 el0 路径后进入同一类处理" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="335" y="455" width="160" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="t5" value="el1_interrupt()&#xa;irq_enter_rcu(); do_interrupt_handler(); irq_exit_rcu()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="335" y="625" width="160" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="t6" value="handle_arch_irq(regs)&#xa;注册阶段已被 set_handle_irq() 设为 gic_handle_irq" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="335" y="795" width="160" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="t7" value="gic_handle_irq()&#xa;进入 GIC 驱动的顶层分发" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="75" y="795" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t8" value="gic_read_iar()&#xa;读 IAR，拿到 INTID/hwirq；特殊号 1020-1023 表示 spurious/special" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="75" y="950" width="160" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="t9" value="gic_complete_ack()&#xa;对 GIC 做 EOI/ack；之后把 hwirq 交给 irq_domain" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="75" y="1130" width="160" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="t10" value="generic_handle_domain_irq(domain, hwirq)&#xa;用注册阶段建好的 irq_domain 找 virq/desc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="590" y="1130" width="170" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="t11" value="generic_handle_irq_desc(desc)&#xa;进入 desc->handle_irq，即 flow handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="590" y="1300" width="170" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="t12" value="flow handler&#xa;handle_fasteoi_irq / handle_level_irq / handle_edge_irq；负责 mask/ack/eoi/retrigger 语义" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="590" y="1460" width="170" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t13" value="handle_irq_event()&#xa;遍历 desc->action 链表" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="590" y="1645" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t14" value="action->handler(irq, dev_id)&#xa;真正进入驱动注册的 hardirq handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="1645" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t15" value="返回值决定后续&#xa;IRQ_HANDLED：完成&#xa;IRQ_WAKE_THREAD：唤醒 threaded IRQ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="1475" width="170" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="t_note1" value="触发路径的核心跳转&#xa;硬件只知道 INTID/hwirq；Linux 通过 irq_domain 找 desc；desc 通过 action 找驱动 handler。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="185" width="430" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="t_note2" value="读代码锚点&#xa;arch/arm64/kernel/entry-common.c：exception 入口&#xa;drivers/irqchip/irq-gic-v3.c：gic_handle_irq / IAR / EOI&#xa;kernel/irq/irqdesc.c：generic_handle_irq_desc&#xa;kernel/irq/chip.c：flow handlers&#xa;kernel/irq/handle.c：调用 irqaction handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="330" width="430" height="165" as="geometry"/>
        </mxCell>
