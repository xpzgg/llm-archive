<mxfile host="app.diagrams.net" modified="2026-05-28T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="register_model" name="中断注册心智模型">
    <mxGraphModel dx="1280" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="r_title" value="Linux arm64 中断注册：建立“硬件中断号 -> Linux IRQ -> 驱动 handler”的地图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="90" y="30" width="920" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r_lane_hw" value="硬件描述 / GIC" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="180" height="1510" as="geometry"/>
        </mxCell>
        <mxCell id="r_lane_core" value="irq core / irq_domain" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#e1f5e1;strokeColor=#82b366;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="110" width="390" height="1510" as="geometry"/>
        </mxCell>
        <mxCell id="r_lane_drv" value="设备驱动" style="swimlane;horizontal=0;html=1;startSize=36;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="670" y="110" width="390" height="1510" as="geometry"/>
        </mxCell>
        <mxCell id="r_hw1" value="DT / ACPI 描述中断控制器&#xa;GIC distributor / redistributor / CPU interface" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="130" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="r_core1" value="start_kernel() -> init_IRQ() -> irqchip_init()&#xa;启动期扫描 irqchip，并找到 GIC 驱动" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="170" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_core2" value="gic_of_init() / gic_acpi_init()&#xa;初始化 GIC 基址、per-cpu redistributor、默认 mask/priority" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="310" width="290" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r_core3" value="创建 irq_domain&#xa;核心意义：把 GIC INTID/hwirq 翻译成 Linux virq" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="460" width="290" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r_core4" value="set_handle_irq(gic_handle_irq)&#xa;把 arm64 顶层 IRQ 入口接到 GIC 分发器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="610" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_hw2" value="设备节点 interrupt spec&#xa;例：GIC_SPI + INTID + trigger flags" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="760" width="130" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="r_drv1" value="driver probe()&#xa;驱动拿到设备资源，准备申请 IRQ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="760" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_drv2" value="platform_get_irq() / of_irq_get()&#xa;解析设备 interrupt spec，得到 fwspec" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="900" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_core5" value="irq_create_fwspec_mapping()&#xa;调用 irq_domain ops：translate / alloc / map" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="900" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_core6" value="分配或查找 virq + irq_desc&#xa;desc 是 Linux 管这个中断的软件对象" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="1040" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r_core7" value="填充 irq_data / irq_chip / flow handler&#xa;irq_data 记 hwirq；irq_chip 指向 GIC mask/unmask/eoi；flow handler 决定 level/edge/fasteoi 语义" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="275" y="1180" width="340" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="r_drv3" value="request_irq() / devm_request_irq()&#xa;驱动提交：virq、handler、flags、name、dev_id" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="1180" width="290" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r_core8" value="request_threaded_irq() -> __setup_irq()&#xa;创建 irqaction，挂到 desc->action 链表" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="1340" width="290" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="r_core9" value="irq_startup() / irq_enable()&#xa;通过 irq_chip 调 GIC unmask，硬件中断真正放行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="1490" width="290" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="r_drv4" value="读代码时记住这个结果&#xa;设备的 hwirq 已经能找到 desc；desc->action 已经能找到驱动 handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eadcf8;strokeColor=#9673a6;fontSize=15;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="1490" width="290" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="r_note1" value="关键数据结构关系&#xa;hwirq/INTID -> irq_domain -> virq -> irq_desc&#xa;irq_desc -> irq_data -> irq_chip(GIC ops)&#xa;irq_desc -> irqaction -> driver handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="705" y="330" width="320" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="r_note2" value="源码锚点&#xa;drivers/irqchip/irq-gic-v3.c&#xa;kernel/irq/irqdomain.c&#xa;kernel/irq/manage.c&#xa;include/linux/irqdesc.h / irq.h" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="705" y="520" width="320" height="140" as="geometry"/>
        </mxCell>
