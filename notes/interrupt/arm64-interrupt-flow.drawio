<mxfile host="app.diagrams.net" modified="2026-05-28T00:00:00.000Z" agent="Claude" version="24.7.17" type="device">
  <diagram id="register_model" name="中断注册心智模型">
    <mxGraphModel dx="1280" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="r_title" value="Linux arm64 中断注册：建立 hwirq -&gt; Linux IRQ -&gt; 驱动 handler 的地图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="25" width="1000" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r_bg" value="GICv3 四种中断类型&#xa;SGI (INTID 0-15)：核间IPI，软件触发&#xa;PPI (INTID 16-31)：每CPU私有，如timer、PMU&#xa;SPI (INTID 32-1019)：共享外设中断&#xa;LPI (INTID &gt;= 8192)：基于ITS，如PCIe MSI/MSI-X&#xa;颜色：黄=硬件/GIC | 绿=内核IRQ core | 粉=设备驱动" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=14;spacing=8;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="50" y="90" width="1000" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="r_ph1" value="Phase 1：中断控制器初始化（启动阶段）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#cccccc;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="230" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="r1" value="start_kernel() -&gt; init_IRQ() -&gt; irqchip_init()&#xa;启动期扫描irqchip，找到GIC驱动" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="285" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="gic_of_init() / gic_acpi_init()&#xa;初始化GIC基址、per-cpu redistributor、默认mask/priority" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="360" width="990" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="创建 irq_domain&#xa;核心意义：把GIC INTID/hwirq翻译成Linux virq" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="450" width="990" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="set_handle_irq(gic_handle_irq)&#xa;把arm64顶层IRQ入口接到GIC分发器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="535" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r_ph2" value="Phase 2：设备中断映射（驱动probe阶段）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#cccccc;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="610" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="r5" value="DT / ACPI 描述设备中断&#xa;例：GIC_SPI + INTID + trigger flags" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="665" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6" value="driver probe() -&gt; platform_get_irq() / of_irq_get()&#xa;解析设备interrupt spec，得到fwspec" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="740" width="990" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="r7" value="irq_create_fwspec_mapping()&#xa;调用irq_domain ops：translate / alloc / map" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="825" width="990" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="r8" value="分配或查找 virq + irq_desc&#xa;desc是Linux管这个中断的软件对象" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="910" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r9" value="填充 irq_data / irq_chip / flow handler&#xa;irq_data记hwirq；irq_chip指向GIC mask/unmask/eoi；flow handler决定level/edge/fasteoi语义" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="985" width="990" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r_ph3" value="Phase 3：驱动注册handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#cccccc;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="1085" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="r10" value="request_irq() / devm_request_irq()&#xa;驱动提交：virq、handler、flags、name、dev_id" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1140" width="990" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="r11" value="request_threaded_irq() -&gt; __setup_irq()&#xa;创建irqaction，挂到desc-&gt;action链表" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1225" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r12" value="irq_startup() / irq_enable()&#xa;通过irq_chip调GIC unmask，硬件中断真正放行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1300" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r_result" value="注册完成后的状态：设备的hwirq已能找到desc；desc-&gt;action已能找到驱动handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eadcf8;strokeColor=#9673a6;fontSize=15;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1380" width="990" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r_ds" value="关键数据结构关系&#xa;hwirq/INTID -&gt; irq_domain -&gt; virq -&gt; irq_desc&#xa;irq_desc -&gt; irq_data -&gt; irq_chip (GIC ops)&#xa;irq_desc -&gt; irqaction -&gt; driver handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="50" y="1455" width="480" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r_src" value="源码锚点&#xa;drivers/irqchip/irq-gic-v3.c&#xa;kernel/irq/irqdomain.c&#xa;kernel/irq/manage.c&#xa;include/linux/irqdesc.h / irq.h" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;spacing=8;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="560" y="1455" width="480" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="re1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r3" target="r4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re4" value="irq_domain就绪" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r4" target="r5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re5" value="fwspec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r6" target="r7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r7" target="r8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r8" target="r9"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re8" value="virq" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r9" target="r10"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re9" value="handler" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r10" target="r11"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="r11" target="r12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re11" value="注册完成" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r12" target="r_result"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="trigger_model" name="中断触发心智模型">
    <mxGraphModel dx="1280" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t_title" value="Linux arm64 中断触发：硬件事件如何找到注册时挂上的handler" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="25" width="1000" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t_bg" value="GICv3 四种中断类型：SGI (0-15) 核间IPI | PPI (16-31) 每CPU私有 | SPI (32-1019) 共享外设 | LPI (&gt;=8192) 基于ITS&#xa;特殊INTID 1020-1023 表示spurious/special&#xa;颜色：黄=硬件/GIC | 蓝=arm64架构层 | 绿=内核IRQ core | 粉=驱动handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=14;spacing=8;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="50" y="90" width="1000" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="t_ph1" value="Phase 1：硬件触发" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="外设拉起IRQ line，GIC看到某个INTID pending" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="255" width="990" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="GIC选择目标CPU&#xa;优先级、mask、affinity共同决定是否送达" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="325" width="990" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t_ph2" value="Phase 2：CPU Exception Entry（含NMI/FIQ分支）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="405" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="CPU硬件自动进入IRQ exception&#xa;保存PC/PSR到SPSR_ELx/ELR_ELx，跳到vector（entry.S）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="460" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="el1h_64_irq_handler()（内核态入口；用户态走el0路径后进入同类处理）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="535" width="990" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t5" value="el1_interrupt(regs, handle_arch_irq)&#xa;设置DAIF，根据中断屏蔽状态分支（CONFIG_ARM64_PSEUDO_NMI）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="605" width="990" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t5a" value="__el1_irq（普通IRQ路径）&#xa;irq_enter_rcu()&#xa;do_interrupt_handler(regs, handler)&#xa;irq_exit_rcu()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="680" width="490" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="t5b" value="__el1_pnmi（Pseudo NMI路径）&#xa;irqentry_nmi_enter(regs)&#xa;do_interrupt_handler(regs, handler)&#xa;irqentry_nmi_exit(regs, state)&#xa;不经过RCU、不触发softirq" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;spacing=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="680" width="490" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="t_fiq" value="FIQ路径：el1h_64_fiq_handler -&gt; el1_interrupt(regs, handle_arch_fiq)&#xa;GICv3 Group 0中断通过FIQ向量交付，同样进入NMI分支判断&#xa;条件：CONFIG_ARM64_PSEUDO_NMI &amp;&amp; IRQ已屏蔽 (regs_irqs_disabled)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;spacing=8;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="795" width="990" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="t6" value="do_interrupt_handler() -&gt; handle_arch_irq(regs)&#xa;[即gic_handle_irq，注册阶段由set_handle_irq()设定]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="880" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t_ph3" value="Phase 3：GIC驱动分发" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="955" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="t7" value="gic_handle_irq() -&gt; gic_read_iar()&#xa;读IAR拿到INTID/hwirq（读操作本身就是ack，隐式priority drop）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1010" width="990" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t8" value="gic_write_eoir(irq)：显式priority drop（EOI）&#xa;中断可被重新pending，但尚未deactivate（GICv3两阶段EOI的第一阶段）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1090" width="990" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t_ph4" value="Phase 4：IRQ Core分发与驱动调用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="1170" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="t9" value="generic_handle_domain_irq(domain, hwirq)&#xa;用注册阶段建好的irq_domain找virq -&gt; desc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1225" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t10" value="generic_handle_irq_desc(desc) -&gt; desc-&gt;handle_irq&#xa;即flow handler（注册阶段设定的）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1300" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t11" value="flow handler: handle_fasteoi_irq / handle_level_irq / handle_edge_irq&#xa;负责mask/ack/eoi/retrigger语义" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1375" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t12" value="handle_irq_event() -&gt; 遍历desc-&gt;action链表" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1450" width="990" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="t13" value="action-&gt;handler(irq, dev_id)&#xa;真正进入驱动注册的hardirq handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1515" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t_ph5" value="Phase 5：中断返回与后续处理" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#cccccc;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="1590" width="1040" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="t14" value="handler返回值：IRQ_HANDLED完成 / IRQ_WAKE_THREAD唤醒threaded IRQ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1645" width="990" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="t15" value="gic_finish_irq()：写DIR deactivate（GICv3两阶段EOI的deactivate阶段）&#xa;中断彻底完成，可以再次触发" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1710" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t16" value="irq_exit_rcu() -&gt; invoke_softirq()&#xa;处理softirq（tasklet、net_rx等下半部）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1785" width="990" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t_insight" value="核心跳转：硬件只知道INTID/hwirq -&gt; Linux通过irq_domain找desc -&gt; desc通过action找驱动handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eadcf8;strokeColor=#9673a6;fontSize=15;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="1870" width="990" height="50" as="geometry"/>
        </mxCell>
