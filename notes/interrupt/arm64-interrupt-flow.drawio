        <mxCell id="re11" value="完成注册后的心智状态" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=13;" edge="1" parent="1" source="r_core9" target="r_drv4"><mxGeometry relative="1" as="geometry"/></mxCell>
