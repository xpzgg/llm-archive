From 02753ec305cf3e462bcdf73fc98937379051cffb Mon Sep 17 00:00:00 2001
From: Jiacheng Yu <yujiacheng3@huawei.com>
Date: Tue, 14 Jul 2026 06:23:23 -0700
Subject: [PATCH] params: fix charp corruption on allocation failure

After slab is available, param_set_charp() releases the previous value
and stores charp values in newly allocated memory.

If kmalloc_parameter() fails, the setter returns -ENOMEM with the parameter
left as NULL. zswap can later dereference such a corrupted zpool value
when zswap is enabled after a failed zpool update.

Allocate and copy the replacement first, then publish it and free the old
value only after allocation succeeds.

Fixes: e180a6b7759a ("param: fix charp parameters set via sysfs")
Cc: stable@vger.kernel.org
Signed-off-by: Jiacheng Yu <yujiacheng3@huawei.com>
---
 kernel/params.c | 19 ++++++++++++-------
 1 file changed, 12 insertions(+), 7 deletions(-)

diff --git a/kernel/params.c b/kernel/params.c
index 9d09ea99363f..6dcc1f905ec7 100644
--- a/kernel/params.c
+++ b/kernel/params.c
@@ -264,22 +264,27 @@ EXPORT_SYMBOL_GPL(param_set_uint_minmax);
 
 int param_set_charp(const char *val, const struct kernel_param *kp)
 {
-	if (strlen(val) > 1024) {
+	char *tmp;
+	size_t len;
+
+	len = strlen(val);
+	if (len > 1024) {
 		pr_err("%s: string parameter too long\n", kp->name);
 		return -ENOSPC;
 	}
 
-	maybe_kfree_parameter(*(char **)kp->arg);
-
 	/* This is a hack.  We can't kmalloc in early boot, and we
 	 * don't need to; this mangled commandline is preserved. */
 	if (slab_is_available()) {
-		*(char **)kp->arg = kmalloc_parameter(strlen(val)+1);
-		if (!*(char **)kp->arg)
+		tmp = kmalloc_parameter(len + 1);
+		if (!tmp)
 			return -ENOMEM;
-		strcpy(*(char **)kp->arg, val);
+		strscpy(tmp, val, len + 1);
 	} else
-		*(const char **)kp->arg = val;
+		tmp = (char *)val;
+
+	*(char **)kp->arg = tmp;
+	maybe_kfree_parameter(*(char **)kp->arg);
 
 	return 0;
 }
-- 
